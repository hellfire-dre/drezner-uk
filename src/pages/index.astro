---
---
const domain = "drezner.uk";

const links = [
  {
    name: "Plex",
    url: "#",
    icon: "plex"
  },
  {
    name: "Access",
    url: "#",
    icon: "lock"
  }
];

function getIcon(type) {
  if (type === "plex") {
    return `
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <polygon points="8,5 16,12 8,19"></polygon>
      </svg>
    `;
  }

  if (type === "lock") {
    return `
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="5" y="11" width="14" height="10" rx="2"></rect>
        <path d="M8 11V7a4 4 0 0 1 8 0v4"></path>
      </svg>
    `;
  }

  return "";
}

---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{domain}</title>

    <style>
      :root {
        --bg: #020617;
        --card: rgba(15, 23, 42, 0.7);
        --text: #e5e7eb;
        --muted: #94a3b8;
        --accent: #22d3ee;
      }

      body {
        margin: 0;
        font-family: system-ui, -apple-system, sans-serif;
        color: var(--text);
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at 20% 20%, #0f172a, #020617);
        overflow: hidden;
      }

      /* subtle animated background glow */
      body::before {
        content: "";
        position: absolute;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(34,211,238,0.15), transparent 70%);
        top: -100px;
        left: -100px;
        animation: moveGlow 12s infinite alternate ease-in-out;
        filter: blur(40px);
      }

      @keyframes moveGlow {
        to {
          transform: translate(200px, 150px);
        }
      }

      .container {
        text-align: center;
        animation: fadeIn 1s ease forwards;
        opacity: 0;
      }

      /* Logo */
      .logo {
        font-size: 3rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        margin-bottom: 0.5rem;
        background: linear-gradient(135deg, #22d3ee, #818cf8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .domain {
        font-size: 0.9rem;
        color: var(--muted);
        margin-bottom: 2rem;
      }

      .links {
        display: flex;
        gap: 1.2rem;
        justify-content: center;
      }

      .card {
        backdrop-filter: blur(10px);
        background: var(--card);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 16px;
        padding: 1.2rem 1.6rem;
        text-decoration: none;
        color: var(--text);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.6rem;
        min-width: 110px;
        transition: all 0.25s ease;
      }

      .card:hover {
        transform: translateY(-6px) scale(1.04);
        border-color: rgba(34,211,238,0.4);
        box-shadow: 0 15px 35px rgba(0,0,0,0.5);
      }

      .icon {
        width: 26px;
        height: 26px;
        opacity: 0.9;
      }

      .label {
        font-size: 0.85rem;
        color: var(--muted);
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>
  </head>

  <body>
    <div class="container">
      <div class="logo">D2</div>
      <div class="domain">{domain}</div>

      <div class="links">
        {links.map(link => (
          <a href={link.url} class="card">
            <div class="icon" set:html={getIcon(link.icon)}></div>
            <div class="label">{link.name}</div>
          </a>
        ))}
      </div>
    </div>
  </body>
</html>
