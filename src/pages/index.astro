---
const domain = "drezner.uk";

const links = [
  {
    name: "Plex",
    url: "#",
    icon: "plex",
  },
  {
    name: "Access",
    url: "#",
    icon: "lock",
  },
];

function getIcon(type) {
  if (type === "plex") {
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <polygon points="8,5 16,12 8,19"></polygon>
    </svg>`;
  }

  if (type === "lock") {
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="5" y="11" width="14" height="10" rx="2"></rect>
      <path d="M8 11V7a4 4 0 0 1 8 0v4"></path>
    </svg>`;
  }

  return "";
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{domain}</title>

    <style>
      body {
        margin: 0;
        font-family: system-ui, sans-serif;
        background: #020617;
        color: #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
      }

      .container {
        text-align: center;
        animation: fadeIn 0.8s ease forwards;
      }

      .logo {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
        background: linear-gradient(135deg, #22d3ee, #818cf8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .domain {
        color: #94a3b8;
        margin-bottom: 2rem;
      }

      .links {
        display: flex;
        gap: 1rem;
        justify-content: center;
      }

      .card {
        background: #0f172a;
        padding: 1rem 1.4rem;
        border-radius: 12px;
        text-decoration: none;
        color: white;
        transition: 0.2s;
      }

      .card:hover {
        transform: translateY(-4px);
      }

      .icon {
        width: 24px;
        height: 24px;
        margin-bottom: 0.3rem;
      }

      .label {
        font-size: 0.8rem;
        color: #94a3b8;
      }

      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
    </style>
  </head>

  <body>
    <div class="container">
      <div class="logo">D2</div>
      <div class="domain">{domain}</div>

      <div class="links">
        {links.map(link => (
          <a href={link.url} class="card">
            <div class="icon" set:html={getIcon(link.icon)}></div>
            <div class="label">{link.name}</div>
          </a>
        ))}
      </div>
    </div>
  </body>
</html>